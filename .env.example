# Database Configuration
# Standard PostgreSQL URL. The application automatically converts postgres:// or postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/doe_scraper

# Scraper & Parser Settings
SYNC_INTERVAL_HOURS=24
HTTP_TIMEOUT_SECONDS=30
MAX_PDF_SIZE_BYTES=10485760 # 10MB in bytes

# Set to false on Render to disable the internal cloud scraper (preventing 403 blocks)
ENABLE_SCRAPER_SCHEDULER=true

# API Security (Required — the server will not start without this)
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secret-api-key-here

# Server Host and Port (Optional, defaults to 0.0.0.0:8000)
HOST=0.0.0.0
PORT=8000
